{
    "name": "@mikelgmh/cookie-manager",
    "version": "1.2.8",
    "description": "A cookies manager that can inject scripts dynamically.",
    "type": "module",
    "main": "dist/index.cjs",
    "module": "dist/index.esm.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.esm.mjs",
            "require": "./dist/index.cjs"
        },
        "./dist/index.css": "./dist/index.css"
    },
    "files": [
        "dist"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/mikelgmh/cookie-manager.git"
    },
    "homepage": "https://github.com/mikelgmh/cookie-manager#readme",
    "bugs": {
        "url": "https://github.com/mikelgmh/cookie-manager/issues",
        "email": "mikelgmh@gmail.com"
    },
    "scripts": {
        "build": "vite build",
        "dev": "vite build --watch",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "author": "Mikel Granero",
    "license": "ISC",
    "devDependencies": {
        "happy-dom": "^20.10.6",
        "sass": "^1.101.0",
        "vite": "^8",
        "vite-plugin-dts": "^4",
        "vitest": "^4.1.9"
    }
}
